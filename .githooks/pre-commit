#!/usr/bin/env bash
# Single pre-commit hook (wired via `core.hooksPath=.githooks`, set by `lki install`):
#   1. Regenerate scripts/git_aliases.bash when .gitconfig is staged.
#   2. Lint/format staged Python files with ruff.
set -euo pipefail

# 1. Regenerate git_aliases.bash from the .gitconfig [alias] section.
if git diff --cached --name-only | grep -q '^\.gitconfig$'; then
  awk -F' *= *' 'BEGIN{print "# Auto-generated from .gitconfig [alias] section"; print "# Regenerated by pre-commit hook when .gitconfig changes"} /^\[alias\]/{f=1;next} /^\[/{f=0} f && /=/{gsub(/^ +/,"",$1); print "alias g"$1"=\"git "$1"\""}' .gitconfig \
    > scripts/git_aliases.bash
  git add scripts/git_aliases.bash
fi

# 2. Lint staged Python files with ruff.
mapfile -t PYTHON_FILES < <(git diff --cached --name-only --diff-filter=ACMR | grep --color=never -E '\.py$' || true)
[[ ${#PYTHON_FILES[@]} -eq 0 ]] && exit 0

# Prefer `uvx ruff` (isolated, no project sync / no uv.lock); fall back to a
# bare `ruff`. On a machine with neither, skip rather than block the commit.
if command -v uvx >/dev/null 2>&1; then
  RUFF=(uvx ruff)
elif command -v ruff >/dev/null 2>&1; then
  RUFF=(ruff)
else
  echo "pre-commit: neither uvx nor ruff found; skipping python lint" >&2
  exit 0
fi

echo "Running ruff check --fix..."
"${RUFF[@]}" check --fix "${PYTHON_FILES[@]}"
echo "Running ruff format..."
"${RUFF[@]}" format "${PYTHON_FILES[@]}"
git add "${PYTHON_FILES[@]}"
echo "Running ruff check..."
"${RUFF[@]}" check "${PYTHON_FILES[@]}"
